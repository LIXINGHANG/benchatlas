        {"id": "science-research", "label_en": "Science & research", "label_zh": "科学与研究", "match_patterns": ["science", "research", "frontier", "chem", "physics"]},
        {"id": "cybersecurity", "label_en": "Cybersecurity", "label_zh": "网络安全", "match_patterns": ["cyber", "exploit", "security", "ctf"]},
        {"id": "professional-work", "label_en": "Professional work", "label_zh": "专业任务", "match_patterns": []}
