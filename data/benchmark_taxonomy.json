      "label_zh": "语言与长上下文",
      "source_domains": ["language", "multilingual", "long_context"],
      "default_subfield": "language-understanding",
      "subfields": [
        {"id": "long-context", "label_en": "Long context", "label_zh": "长上下文", "match_patterns": ["long", "context", "needle", "mrcr", "graphwalk", "memory"]},
        {"id": "multilingual", "label_en": "Multilingual", "label_zh": "多语言", "match_patterns": ["multi", "language", "mmlu-prox", "global"]},
        {"id": "translation", "label_en": "Translation", "label_zh": "翻译", "match_patterns": ["wmt", "translation", "xcomet"]},
        {"id": "language-understanding", "label_en": "Language understanding", "label_zh": "语言理解", "match_patterns": []}
