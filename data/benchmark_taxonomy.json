  "safety_domains": ["safety", "agent_safety", "bio_safety", "computer_use_safety", "cyber_safety", "health_safety", "safety_bias", "safety_health", "vision_safety"],
  "benchmark_overrides": {
    "AetherCode": {"source_domain": "coding", "subfield": "code-generation", "confidence": 1.0, "reason": "Coding benchmark"},
    "ArcAGI2": {"source_domain": "reasoning", "subfield": "general-reasoning", "confidence": 1.0, "reason": "Abstract reasoning benchmark"},
    "BeyondAIME": {"source_domain": "reasoning", "subfield": "mathematics", "confidence": 1.0, "reason": "Mathematics benchmark"},
    "BrowseComp": {"source_domain": "agent", "subfield": "web-search", "confidence": 1.0, "reason": "Web browsing and search benchmark"},
    "FrontierScience-Olympiad": {"source_domain": "science", "subfield": "science-research", "confidence": 1.0, "reason": "Frontier science benchmark"},
    "FS - Research": {"source_domain": "research", "subfield": "science-research", "confidence": 1.0, "reason": "Research benchmark"},
    "HLE-textonly": {"source_domain": "agent", "confidence": 0.9, "reason": "Source report evaluates it in the agent section"},
    "HLE-Verified": {"source_domain": "reasoning", "subfield": "knowledge", "confidence": 1.0, "reason": "Knowledge and reasoning benchmark"},
    "KINA": {"source_domain": "reasoning", "subfield": "knowledge", "confidence": 1.0, "reason": "Knowledge benchmark"},
    "LiveMathematicianBench": {"source_domain": "reasoning", "subfield": "mathematics", "confidence": 1.0, "reason": "Mathematics benchmark"},
    "MathArena Apex": {"source_domain": "reasoning", "subfield": "mathematics", "confidence": 1.0, "reason": "Mathematics benchmark"},
    "MMLU": {"source_domain": "reasoning", "subfield": "knowledge", "confidence": 1.0, "reason": "General knowledge benchmark; multilingual variants remain separate"},
    "MSQA": {"source_domain": "multilingual", "subfield": "multilingual", "confidence": 1.0, "reason": "Multilingual question answering benchmark"},
    "PostTrainBench": {"source_domain": "reasoning", "subfield": "general-reasoning", "confidence": 0.9, "reason": "Post-training reasoning evaluation"},
    "SuperChem": {"source_domain": "science", "subfield": "science-research", "confidence": 1.0, "reason": "Chemistry benchmark"}
  },
  "map_families": [
    {
      "id": "healthbench",
      "name_pattern": "^HealthBench(?:\\s|$)",
      "representative_pattern": "^HealthBench$"
    }
  ]
