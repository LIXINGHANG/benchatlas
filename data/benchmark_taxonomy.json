{
  "schema_version": 1,
  "description": "Canonical BenchAtlas taxonomy. Extraction supplies a provisional source domain; this file resolves the public primary domain, subfield, safety layer, and map family.",
  "fallback_primary_domain": "reason",
  "primary_domains": [
    {
      "id": "reason",
      "label_en": "Reasoning & Knowledge",
      "label_zh": "推理与知识",
      "source_domains": ["reasoning", "math", "general", "general_capability", "safety", "safety_bias"],
      "default_subfield": "general-reasoning",
      "subfields": [
        {"id": "mathematics", "label_en": "Mathematics", "label_zh": "数学", "match_patterns": ["aime", "hmmt", "imo", "math", "olympiad"]},
        {"id": "knowledge", "label_en": "Knowledge", "label_zh": "知识", "match_patterns": ["gpqa", "mmlu", "supergpqa", "knowledge", "kina", "hle", "humanity"]},
        {"id": "general-reasoning", "label_en": "General reasoning", "label_zh": "通用推理", "match_patterns": []}
      ]
    },
    {
      "id": "code",
      "label_en": "Coding & Software Engineering",
      "label_zh": "编程与软件工程",
      "source_domains": ["coding"],
      "default_subfield": "repository-reasoning",
      "subfields": [
        {"id": "software-engineering", "label_en": "Software engineering", "label_zh": "软件工程", "match_patterns": ["swe", "repo", "patch", "issue", "deepswe"]},
        {"id": "terminal-systems", "label_en": "Terminal & systems", "label_zh": "终端与系统", "match_patterns": ["terminal", "kernel", "cuda", "cyber", "shell"]},
        {"id": "code-generation", "label_en": "Code generation", "label_zh": "代码生成", "match_patterns": ["code", "program", "scicode", "artificial analysis"]},
        {"id": "repository-reasoning", "label_en": "Repository reasoning", "label_zh": "代码仓库推理", "match_patterns": []}
      ]
    },
    {
      "id": "agent",
      "label_en": "Agents & Computer Use",
      "label_zh": "智能体与计算机操作",
      "source_domains": ["agent", "computer_use", "business_simulation", "healthcare_agent", "computer_use_safety", "agent_safety"],
      "default_subfield": "workflows",
      "subfields": [
        {"id": "computer-use", "label_en": "Computer use", "label_zh": "计算机操作", "match_patterns": ["osworld", "computer", "benchcad", "android", "browser"]},
        {"id": "tools-mcp", "label_en": "Tools & MCP", "label_zh": "工具与 MCP", "match_patterns": ["tool", "mcp", "api", "function"]},
        {"id": "web-search", "label_en": "Web & search", "label_zh": "Web 与搜索", "match_patterns": ["browse", "search", "web"]},
        {"id": "workflows", "label_en": "Workflows", "label_zh": "工作流", "match_patterns": []}
      ]
    },
    {
      "id": "multi",
      "label_en": "Multimodal & Perception",
      "label_zh": "多模态与感知",
      "source_domains": ["multimodal", "multimodal_agent", "vision", "video", "document", "vision_safety"],
      "default_subfield": "spatial-perception",
      "subfields": [
        {"id": "visual-reasoning", "label_en": "Visual reasoning", "label_zh": "视觉推理", "match_patterns": ["mmmu", "vision", "image", "chart", "charxiv", "visual"]},
        {"id": "video", "label_en": "Video", "label_zh": "视频", "match_patterns": ["video", "tvbench", "crossvid"]},
        {"id": "documents", "label_en": "Documents", "label_zh": "文档", "match_patterns": ["document", "doc", "pdf", "dude"]},
        {"id": "spatial-perception", "label_en": "Spatial perception", "label_zh": "空间理解", "match_patterns": []}
